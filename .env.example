# ── LLM provider selection ────────────────────────────────
# "gemini" (default) or "mock" (deterministic, offline — used by tests)
LLM_PROVIDER=gemini

# ── Google Gemini (Google AI Studio, free tier) ───────────
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-key-here
# gemini-3.1-flash-lite is reliable on the free tier; gemini-3.5-flash is
# smarter but frequently overloaded (503) on free-tier keys.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Server ────────────────────────────────────────────────
PORT=3000
